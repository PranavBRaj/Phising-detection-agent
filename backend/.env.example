# Fraud Detection API - Environment Configuration
# Copy this file to .env and fill in your values

# ── Database ─────────────────────────────────────────────────────────────────
# Format: mysql+pymysql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=mysql+pymysql://root:Your_Password@localhost/Your_Schema_Name

# ── Server ────────────────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# Set to true to enable auto-reload and debug logging
DEBUG=false

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Use * for all origins (development only).
# For production, restrict to your extension's origin:
#   chrome-extension://<extension-id>
ALLOWED_ORIGINS=*

# ── URL Analysis ──────────────────────────────────────────────────────────────
# Seconds to wait for a URL response before timing out
REQUEST_TIMEOUT=10
# Maximum number of redirects to follow per URL
MAX_REDIRECTS=10
